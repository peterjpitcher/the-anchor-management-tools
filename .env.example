# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-domain.com # Optional fallback public site URL
NEXT_PUBLIC_CONTACT_PHONE_NUMBER=01234567890
NEXT_PUBLIC_SHORT_LINK_BASE_URL=https://vip-club.uk

# SMS Safety Flags (Optional)
SUSPEND_EVENT_SMS=false
SUSPEND_ALL_SMS=false

# SMS Safety Guards (Optional - defaults shown)
SMS_SAFETY_GUARDS_ENABLED=true
SMS_SAFETY_GLOBAL_HOURLY_LIMIT=120
SMS_SAFETY_RECIPIENT_HOURLY_LIMIT=3
SMS_SAFETY_RECIPIENT_DAILY_LIMIT=8
SMS_SAFETY_IDEMPOTENCY_TTL_HOURS=336

# Cron Send Guards (Optional - defaults shown)
EVENT_ENGAGEMENT_SEND_GUARD_WINDOW_MINUTES=60
EVENT_ENGAGEMENT_HOURLY_SEND_GUARD_LIMIT=120
SUNDAY_PREORDER_SEND_GUARD_WINDOW_MINUTES=60
SUNDAY_PREORDER_SEND_GUARD_LIMIT=80
MAX_SUNDAY_PREORDER_SMS_PER_RUN=80
PARKING_SEND_GUARD_WINDOW_MINUTES=60
PARKING_SEND_GUARD_LIMIT=80

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
TWILIO_MESSAGING_SERVICE_SID=your_messaging_service_sid # Optional - use messaging service instead of from number
TWILIO_WEBHOOK_AUTH_TOKEN=your_webhook_auth_token
SKIP_TWILIO_SIGNATURE_VALIDATION=true # Only for local development

# Webhook Configuration
WEBHOOK_BASE_URL=https://your-domain.com # Override for webhook callbacks (defaults to NEXT_PUBLIC_APP_URL)

# Microsoft Graph Configuration (Email)
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_TENANT_ID=your_microsoft_tenant_id
MICROSOFT_USER_EMAIL=your_email@domain.com
PRIVATE_BOOKINGS_MANAGER_EMAIL=manager@the-anchor.pub

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id
PAYPAL_ENVIRONMENT=live  # 'sandbox' for testing, 'live' for production
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id  # same value as PAYPAL_CLIENT_ID; exposed to browser for PayPal JS SDK

# Stripe Configuration (Event payments)
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google Calendar Configuration (Optional)
GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Cron Secret (for Vercel cron jobs)
CRON_SECRET=your_cron_secret
PRIVATE_BOOKINGS_DAILY_DIGEST_HOUR_LONDON=9

# Cron failure alert recipient — receives an email when a cron job fails (optional)
CRON_ALERT_EMAIL=manager@the-anchor.pub

# GitHub Bug Reporting (Optional)
GITHUB_BUG_REPORTER_TOKEN=ghp_your_token
GITHUB_OWNER=your_github_org_or_user
GITHUB_REPO=your_repo_name

# Google Calendar Extended (Optional - for service account / delegate access)
GOOGLE_CALENDAR_DELEGATE_EMAIL=delegate@your-domain.com
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# OpenAI (Optional - for AI-assisted receipt parsing)
OPENAI_API_KEY=sk-your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1 # Override for proxy/compatible endpoints
OPENAI_RECEIPTS_MODEL=gpt-4o-mini

# Job Queue (Optional - defaults shown)
JOB_QUEUE_DEBUG=false
JOB_QUEUE_STALE_MINUTES=10

# Event Checklist Reminders
EVENT_CHECKLIST_EMAIL_RECIPIENT=manager@the-anchor.pub

# Bulk SMS
BULK_SMS_MAX_RECIPIENTS=200

# Private Booking Cron
MAX_PRIVATE_BOOKING_SMS_PER_RUN=20
PRIVATE_BOOKING_UPCOMING_EVENT_SMS_ENABLED=true

# Rota / Payroll Email Recipients
ROTA_MANAGER_EMAIL=manager@the-anchor.pub  # Recipient for weekly rota manager alert cron
PAYROLL_ACCOUNTANT_EMAIL=accountant@the-anchor.pub  # Recipient for payroll export emails

# Employee Management Email Recipients
MANAGER_EMAIL=manager@the-anchor.pub  # Recipient for birthday reminders and onboarding complete emails

# Company Contact (used in invoices, quotes, email signatures)
COMPANY_CONTACT_NAME=Peter Pitcher  # Contact name on invoices, quotes, and emails
COMPANY_CONTACT_PHONE=07995087315  # Contact mobile on invoices, quotes, and emails

# Employee Document Email Identity
COMPANY_LEGAL_NAME=Orange Jelly Limited  # Used in employee document emails
DOCUMENT_EMAIL_SENDER=Peter Pitcher  # Sender name used in employee document emails

# Rota ICS feed secret — if set, used directly as the token in the calendar feed URL.
# If not set, falls back to SHA-256(SUPABASE_SERVICE_ROLE_KEY) for backwards compatibility.
# Set this to a long random string and update any existing calendar subscriptions.
ROTA_FEED_SECRET=

# CORS — restrict API cross-origin access to known domains (defaults to '*' if unset)
CORS_ALLOWED_ORIGIN=https://www.the-anchor.pub

# Event cross-promotion (optional — all have defaults)
# EVENT_PROMO_LOOKAHEAD_DAYS=14
# MAX_EVENT_PROMOS_PER_RUN=100
# EVENT_PROMO_HOURLY_SEND_GUARD_LIMIT=120
# EVENT_PROMO_REPLY_WINDOW_HOURS=48
# EVENT_PROMO_MAX_SEATS=10
# EVENT_PROMO_MIN_CAPACITY=10
# EVENT_PROMO_FREQUENCY_CAP_DAYS=7
# EVENT_PROMO_MAX_RECIPIENTS_PER_EVENT=100
